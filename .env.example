# Központi sablon — másold `.env` néven a repó gyökerébe (szakdolgozat/.env).

# ========== Backend (FastAPI / uvicorn) ==========
DATABASE_URL=mysql+pymysql://felhasznalo:jelszo@localhost:3306/adatbazis_nev
JWT_SECRET_KEY=valtoztasd-meg-produkciora

# Mely origin-ek hívhatják az API-t (nem a backend portja!)
# CORS_ORIGINS=* fejlesztéshez; élesben szűkítheted.
CORS_ORIGINS=*

MAILJET_API_KEY=
MAILJET_API_SECRET=
PUBLIC_SITE_URL=http://localhost:5173
MAIL_FROM_EMAIL=te@pelda.hu
MAIL_FROM_NAME=Enaplo

# ========== Frontend (Vite) ==========
# Backend HTTP port — a böngésző ezt használja az API címhez (éles build, host+:port).
# uvicorn: uvicorn app.main:app --host 0.0.0.0 --port 8000  (ugyanaz a szám)
VITE_API_PORT=8000

# Teljes API URL, ha nem a fenti {host}:{VITE_API_PORT} logika kell (pl. külön API szerver):
# VITE_API_BASE_URL=https://api.pelda.hu

# Opcionális
# VITE_AUTH_PERSIST=local
# VITE_PHPMYADMIN_URL=http://localhost/phpmyadmin
